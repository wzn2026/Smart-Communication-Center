# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here-change-before-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://scc_user:scc_pass@localhost:5432/scc_db

# ─── Celery / Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── WhatsApp Provider ────────────────────────────────────────────────────────
# Options: mock (local dev) | 360dialog (production)
WHATSAPP_PROVIDER=mock

# 360dialog — required when WHATSAPP_PROVIDER=360dialog
DIALOG360_API_KEY=

# ─── Webhook Security ─────────────────────────────────────────────────────────
# Set this to the secret configured in your 360dialog dashboard.
# Webhooks without a valid HMAC-SHA256 signature will be rejected in production.
# Leave empty for local mock testing (DEBUG=true bypasses validation).
WEBHOOK_SECRET=

# ─── Field Encryption ─────────────────────────────────────────────────────────
# REQUIRED in production. Used to encrypt provider API keys stored per-number.
# Generate with: openssl rand -base64 32
# WARNING: losing this key means losing access to all encrypted credentials.
FIELD_ENCRYPTION_KEY=

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_FAQ_AUTOREPLY=true
ENABLE_AI_AUTOREPLY=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Rate Limiting (DRF Throttling) ──────────────────────────────────────────
# Format: N/second | N/minute | N/hour | N/day
THROTTLE_ANON=200/hour
THROTTLE_USER=2000/hour
THROTTLE_WEBHOOK=300/min
THROTTLE_MOCK_INBOUND=60/min
THROTTLE_EXTERNAL_EVENTS=120/min
THROTTLE_LOGIN=10/min
