# ─── Smart Communication Center — Production Environment ─────────────────────
# Copy to .env.production and fill EVERY value before deploying.
# NEVER commit .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────

# Always False in production (production.py enforces this, but explicit is safer)
DEBUG=false

# Generate: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=CHANGE_ME_long_random_string

# Comma-separated allowed hosts
ALLOWED_HOSTS=api.comm.wasal.sa,app.comm.wasal.sa

# Comma-separated trusted CSRF origins (must match your domains)
CSRF_TRUSTED_ORIGINS=https://api.comm.wasal.sa,https://app.comm.wasal.sa

# Comma-separated CORS allowed origins (frontend domain)
CORS_ALLOWED_ORIGINS=https://app.comm.wasal.sa

# Set to true only if Nginx terminates SSL (not needed if Cloudflare Flexible/Full handles it)
SECURE_SSL_REDIRECT=false

# HSTS in seconds — start at 0, increase after SSL is confirmed stable
SECURE_HSTS_SECONDS=0

# Log level for app/services loggers (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────

# Must match POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB below
DATABASE_URL=postgresql://scc_user:CHANGE_ME_db_password@postgres:5432/scc_db

POSTGRES_DB=scc_db
POSTGRES_USER=scc_user
POSTGRES_PASSWORD=CHANGE_ME_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0
CHANNEL_LAYER_REDIS_URL=redis://redis:6379/1

# ── WhatsApp Provider ─────────────────────────────────────────────────────────

# Options: mock | 360dialog
WHATSAPP_PROVIDER=mock

# Required when WHATSAPP_PROVIDER=360dialog
DIALOG360_API_KEY=

# Required when WHATSAPP_PROVIDER=360dialog
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# ── Field-level Encryption ────────────────────────────────────────────────────

# REQUIRED in production. Encrypts api_key/webhook_secret in WhatsAppNumber.settings.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: losing this key makes all encrypted fields unreadable. Back it up securely.
FIELD_ENCRYPTION_KEY=CHANGE_ME_fernet_key

# ── Feature flags ─────────────────────────────────────────────────────────────

ENABLE_FAQ_AUTOREPLY=true
ENABLE_AI_AUTOREPLY=false

# ── Rate limiting (requests per window) ──────────────────────────────────────

THROTTLE_ANON=200/hour
THROTTLE_USER=2000/hour
THROTTLE_WEBHOOK=300/min
THROTTLE_MOCK_INBOUND=60/min
THROTTLE_EXTERNAL_EVENTS=120/min
THROTTLE_LOGIN=10/min
